# DeepSeek API（兼容 OpenAI 接口）—— 主观题判分用
# 复制本文件为 .env 并填入真实 key；.env 已被 .gitignore 忽略，不会被提交
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 小米 MiMo 多模态（OpenAI 兼容接口）—— 看图读答案（学生作答 + 标准答案）
# 申请：https://mimo.xiaomi.com
MIMO_API_KEY=sk-your-mimo-key-here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5
# 简单访问鉴权：前端请求头需带 X-Access-Token 与此一致
ACCESS_TOKEN=change-me-to-a-long-random-string

# CORS 允许的前端来源（开发期留 *）
CORS_ORIGINS=*

# 上传/生成文件目录
DATA_DIR=./_data
